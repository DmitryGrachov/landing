# HTTP port this service listens on
PORT=4100

# Origin(s) allowed to call this API from the browser (comma-separated).
# The main site's dev server runs on 5173.
CORS_ORIGIN=http://localhost:5173

# Telegram bot used to notify about new leads (contact form submissions).
# Currently DISABLED (see lead.service.ts) — Telegram was unreachable from
# the prod server. Not read by the app right now; left here for when it's
# re-enabled. Token comes from @BotFather; chat id is the user/group/channel
# to post to (message the bot once, then call
# https://api.telegram.org/bot<token>/getUpdates to read back the chat id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Resend (resend.com) used to also email new leads. API key from
# Resend dashboard -> API Keys. Without a verified sending domain, the
# default sandbox sender (RESEND_FROM_EMAIL) can only deliver to the email
# address the Resend account itself was signed up with.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
LEAD_NOTIFY_EMAIL=
