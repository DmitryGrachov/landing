# HTTP port this service listens on
PORT=4100

# Origin(s) allowed to call this API from the browser (comma-separated).
# The main site's dev server runs on 5173.
CORS_ORIGIN=http://localhost:5173

# Telegram bot used to notify about new leads (contact form submissions).
# Token comes from @BotFather; chat id is the user/group/channel to post to
# (message the bot once, then call https://api.telegram.org/bot<token>/getUpdates
# to read back the chat id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
