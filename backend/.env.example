# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gallery?schema=public"

# HTTP port the gallery backend listens on
PORT=4000

# Origin(s) allowed to call this API from the browser (comma-separated).
# The main site's dev server runs on 5173, the admin app's on 5174 by default.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Absolute or relative (to backend/) path where uploaded media files are stored
UPLOADS_DIR=uploads

# Max upload size for a single file, in megabytes
MAX_UPLOAD_MB=25
